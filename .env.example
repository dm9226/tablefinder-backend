# === REQUIRED API KEYS ===

# Browserless.io - Free tier: 1,000 units/month
# Sign up at https://www.browserless.io (no credit card required)
BROWSERLESS_API_KEY=your_browserless_key_here

# Google Gemini API - Free tier: 1,500 requests/day
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# === OPTIONAL ===

# Redis URL - defaults to in-memory cache if not set
# Upstash free tier: https://upstash.com (10,000 commands/day)
# Or Render Redis, Railway Redis, etc.
REDIS_URL=

# Server port
PORT=3001

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL=300

# CORS origin for frontend
FRONTEND_URL=http://localhost:3000
